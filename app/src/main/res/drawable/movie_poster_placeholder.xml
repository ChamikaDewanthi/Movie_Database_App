<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background (poster style) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E0E0E0" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Top bar (like movie header strip) -->
    <item android:top="0dp">
        <shape android:shape="rectangle">
            <size android:height="24dp" />
            <solid android:color="#BDBDBD" />
        </shape>
    </item>

    <!-- Center "film" icon placeholder -->
    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="48dp" android:height="48dp" />
            <solid android:color="#9E9E9E" />
        </shape>
    </item>

    <!-- Bottom text line 1 -->
    <item android:gravity="bottom" android:bottom="24dp">
        <shape android:shape="rectangle">
            <size android:width="80dp" android:height="6dp" />
            <solid android:color="#BDBDBD" />
        </shape>
    </item>

    <!-- Bottom text line 2 -->
    <item android:gravity="bottom" android:bottom="12dp">
        <shape android:shape="rectangle">
            <size android:width="60dp" android:height="6dp" />
            <solid android:color="#BDBDBD" />
        </shape>
    </item>

</layer-list>